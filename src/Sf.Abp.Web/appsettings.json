{
  //多租户，支持多库，DbConnOptions会自动创建到默认租户,支持配置文件方式+数据库方式，AbpDefaultTenantStoreOptions
  //  "Tenants": [
  //    {
  //      "Id": "33333333-3d72-4339-9adc-845151f8ada0",
  //      "Name": "Mes@MySql",
  //      "ConnectionStrings": {
  //        "Default": "DataSource=mes-dev.db"
  //      },
  //      "IsActive": false
  //    }
  //  ],
  "Logging": {
    "LogLevel": {
      //"Default": "Information",
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  //应用启动
  "App": {
    "SelfUrl": "http://*:19001",
    "CorsOrigins": "http://localhost:3000;http://localhost:3007;http://localhost:5173;http://localhost:3006;http://localhost:3090"
    // "CorsOrigins": "http://localhost:*"
  },
  //配置
  "Settings": {
    "Test": "hello"
  },
  //数据库类型列表
  "DbList": ["Sqlite", "Mysql", "Sqlserver", "Oracle", "PostgreSQL"],
  "DbConnOptions": {
    //"Url": "DataSource=yi-abp-dev.db",
    "Url": "Host=localhost;Port=5432;Database=sharpfort;Username=postgres;Password=hh112104;Pooling=true;Maximum Pool Size=100;",
    //"DbType": "Sqlite",
    "DbType": "PostgreSQL",
    "EnabledReadWrite": false,
    "EnabledCodeFirst": true,
    "EnabledSqlLog": false,
    "EnabledDbSeed": false,
    "EnableUnderLine": true, // 启用驼峰转下划线
    //SAAS多租户
    "EnabledSaasMultiTenancy": true
    //读写分离地址
    //"ReadUrl": [
    //  "DataSource=[xxxx]", //Sqlite
    //  "server=[xxxx];port=3306;database=[xxxx];user id=[xxxx];password=[xxxx]", //Mysql
    //  "Data Source=[xxxx];Initial Catalog=[xxxx];User ID=[xxxx];password=[xxxx]" //Sqlserver
    //  "HOST=[xxxx];PORT=5432;DATABASE=[xxxx];USERID=[xxxx];PASSWORD=[xxxx]" //PostgreSQL
    //]
  },
  //redis使用freeesql参数在“FreeSqlOptions的ConnectionStringBuilder中”
  "Redis": {
    "IsEnabled": false,
    "Configuration": "127.0.0.1:6379,password=123,defaultDatabase=13",
    "JobDb": 13
  },
  //鉴权 (S-05: SecurityKey 从环境变量读取，此处为空占位符)
  "JwtOptions": {
    "Issuer": "https://ccnetcore.com",
    "Audience": "https://ccnetcore.com",
    "SecurityKey": "",
    "ExpiresMinuteTime": 86400
  },
  //刷新token
  "RefreshJwtOptions": {
    "Issuer": "https://yi.ccnetcore.com",
    "Audience": "https://yi.ccnetcore.com",
    "SecurityKey": "",
    "ExpiresMinuteTime": 172800
  },
  //第三方登录
  "OAuth": {
    //QQ
    "QQ": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": ""
    },
    //码云
    "Gitee": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": ""
    }
  },
  //Rbac模块
  "RbacOptions": {
    //[已废弃]超级管理员种子数据默认密码
    "AdminPassword": "123456",
    // S-09: 是否开启图片验证码（登录）
    "EnableImageCaptcha": false,
    // S-09: 是否开启手机短信验证码（注册/找回密码）
    "EnablePhoneCaptcha": false,
    //是否开启注册功能
    "EnableRegister": true,
    //开启定时数据库备份
    "EnableDataBaseBackup": false
  },
  //Casbin权限控制
  "Casbin": {
    //超级管理员角色代码，拥有该角色的用户跳过所有权限检查
    "SuperAdminRoleCode": "super-admin",
    //是否启用调试模式（支持 X-Casbin-Debug 头）
    "EnableDebugMode": true,
    //是否使用缓存策略（减少每次请求重新加载策略）
    "EnableCachedEnforcer": true,
    //是否启用 Redis Watcher（仅多实例部署时需要，需要Redis支持）
    "EnableRedisWatcher": false,
    //忽略的 URL 前缀（这些 URL 跳过 Casbin 检查）
    //注意：只应该放行真正不需要认证的接口，其他接口应该通过 Casbin 策略控制
    "IgnoreUrls": [
      "exact:/api/app/account",
      "exact:/api/app/account/logout",
      "exact:/api/app/account/update-password",
      "exact:/api/app/account/update-icon",
      "exact:/api/app/account/vue3router",
      "/swagger",
      "/hangfire",
      "/api/app/user",
      "/api/app/role",
      "/api/app/menu"
    ]
  },
  //语义内核
  "SemanticKernel": {
    "ModelIds": ["gpt-4o"],
    "Endpoint": "https://xxx.com/v1",
    "ApiKey": "sk-xxxxxx"
  },
  "FluidSequence": {
    "CacheProvider": "Redis",
    "MaxRetryCount": 5
  }
}
