# .NET Code Style Configuration
# Copy this file to <solution-root>/.editorconfig
# Category-level rules automatically cover new rules Microsoft adds to each category.

root = true

[*.cs]

# ── Safe Auto-Fix (build-visible, dotnet format can fix) ──────────────────
# Category-wide: all Style rules are safe (see exceptions below)
dotnet_analyzer_diagnostic.category-Style.severity = warning

# IDE0008: prefer explicit type over var (var → explicit type)
# Three sub-rules control when var is preferred vs explicit type
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning

# Category-wide: all UnnecessaryCode rules are safe
dotnet_analyzer_diagnostic.category-UnnecessaryCode.severity = warning

# ── Manual Review (editor-visible only, not during build) ─────────────────
# Category-wide: all Naming rules require human judgment
dotnet_analyzer_diagnostic.category-Naming.severity = suggestion

# Category-wide: all Accessibility rules require human judgment
dotnet_analyzer_diagnostic.category-Accessibility.severity = suggestion

# ── Exceptions (safe categories but these specific rules need review) ─────
# IDE0063: using statement → using declaration changes Dispose scope
dotnet_diagnostic.IDE0063.severity = suggestion
# IDE0071: string interpolation simplification may affect culture formatting
dotnet_diagnostic.IDE0071.severity = suggestion
# IDE0160: file-scoped → block-scoped namespace is a style preference; file-scoped is modern C# convention
dotnet_diagnostic.IDE0160.severity = suggestion
# IDE0058: "expression value is never used" — legitimate side-effect calls (StringBuilder.Append, Headers.TryAdd, etc.)
dotnet_diagnostic.IDE0058.severity = suggestion
# IDE0052: "private member can be removed" — aggressively flags DI-injected readonly fields reserved for future use
# and framework-required fields accessed via base class or reflection. Removing them breaks constructor signatures and DI.
dotnet_diagnostic.IDE0052.severity = suggestion
# IDE0046: "if statement can be simplified" — converts if-return to ternary; skip because:
#   (1) if-throw guards are legitimate business logic (DTO validation), ternary throw is unnatural
#   (2) if-return followed by already-ternary return creates nested ternary (hard to read)
dotnet_diagnostic.IDE0046.severity = suggestion
# IDE1006: naming rule violations — suppressed globally because:
#   (A) HTTP/API DTO property names must match external JSON fields (snake_case/camelCase from OAuth/WeChat/Anthropic/OpenAI)
#   (B) SqlSugar framework convention uses _Db, _DbQueryable as public interface members
#   (C) Some private properties intentionally use _camelCase field-style naming
#   Renaming any of these would either break serialization or violate external API contracts.
dotnet_diagnostic.IDE1006.severity = suggestion

# ── Naming Conventions (Microsoft defaults) ───────────────────────────────
# Public members: PascalCase
# Private fields: _camelCase
# Interfaces: IPrefix
# Types: PascalCase
# Parameters: camelCase
# Using .NET built-in defaults — no explicit rules needed unless customizing.

# ── Code Quality Rules ──────────────────────────────────────────────────────
# CA1822: member does not access instance data and can be marked static
dotnet_diagnostic.CA1822.severity = warning
