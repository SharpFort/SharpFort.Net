    <PackageReference Include="UAParser" Version="3.1.47" />

    <PackageReference Include="Volo.Abp.AspNetCore.SignalR" Version="10.2.0" />

    <PackageReference Include="Volo.Abp.Ddd.Domain" Version="10.3.0" />
	  <PackageReference Include="Volo.Abp.Caching" Version="10.3.0" />
    <PackageReference Include="Volo.Abp.Imaging.ImageSharp" Version="10.2.0" />
    <PackageReference Include="Casbin.NET.Adapter.SqlSugar" Version="1.0.3" />
    <PackageReference Include="Casbin.NET.Watcher.Redis" Version="2.0.0" />
	  
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="DistributedLock.Redis" Version="1.1.1" />
    <PackageReference Include="Volo.Abp.DistributedLocking" Version="10.2.0" />
    <PackageReference Include="BCrypt.Net-Next" Version="4.1.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\framework\SharpFort.Caching.FreeRedis\SharpFort.Caching.FreeRedis.csproj" />
    <ProjectReference Include="..\..\..\framework\SharpFort.SqlSugarCore.Abstractions\SharpFort.SqlSugarCore.Abstractions.csproj" />
    <ProjectReference Include="..\SharpFort.CasbinRbac.Domain.Shared\SharpFort.CasbinRbac.Domain.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
